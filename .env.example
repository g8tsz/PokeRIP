# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Supabase ----
# Create a project at https://supabase.com, then get these from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for migrations / server-only queries
# (Supabase: Project Settings > Database > Connection string > URI)
DATABASE_URL=

# ---- Stripe ----
# Create at https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect (for ACH payouts to users)
STRIPE_CONNECT_CLIENT_ID=ca_...

# ---- RNG / Security ----
# 64 hex chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RNG_MASTER_SECRET=

# Comma-separated list of admin emails
ADMIN_EMAILS=

# ---- Compliance ----
# Comma-separated 2-letter state codes where we refuse service. Start cautious.
BLOCKED_US_STATES=WA,ID,NV,MT,CT
# Comma-separated 2-letter country codes; everyone outside these is blocked.
ALLOWED_COUNTRIES=US
